# MongoDB Connection
MONGODB_CONNECTION=mongodb://localhost:27017/hotel-travel

# Server
PORT=5001
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret
SESSION_SECRET=your-session-secret-change-this-in-production

# Google OAuth
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
# Get from: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# Frontend and Backend URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001

# CORS
CORS_ORIGIN=http://localhost:5173

# Email OTP Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# VNPay Payment Gateway
# Test credentials from VNPay (change in production)
VNP_TMN_CODE=2L8QH5HS
VNP_HASH_SECRET=CURLQZJMMF63KMCWL7QX0KGTBLRW03
# Return URL is now dynamically set from frontend, but keep this as fallback
VNP_RETURN_URL=http://localhost:5173/checkout/payment-result
