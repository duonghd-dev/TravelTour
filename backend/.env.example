# MongoDB Connection
MONGODB_CONNECTION=mongodb://localhost:27017/hotel-travel

# Server
PORT=5001
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret
SESSION_SECRET=your-session-secret-change-this-in-production

# 🔐 ENCRYPTION KEY - AES-256-GCM (32 bytes = 64 hex characters)
# Generate new key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED for encrypting messages, payment details, and billing info
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google OAuth
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
# Get from: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# Frontend and Backend URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001

# CORS
CORS_ORIGIN=http://localhost:5173

# Email OTP Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# VNPay Payment Gateway
# Get your own credentials from: https://merchant.vnpayment.vn/
# Test/Production TMN Code and Hash Secret from VNPay merchant dashboard
VNP_TMN_CODE=your-vnpay-tmncode
VNP_HASH_SECRET=your-vnpay-hash-secret
# Return URL is now dynamically set from frontend, but keep this as fallback
VNP_RETURN_URL=http://localhost:5173/checkout/payment-result
